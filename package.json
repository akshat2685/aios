{
  "name": "aios",
  "version": "0.1.0",
  "private": true,
  "description": "Personal AI Operating System - Local-first, privacy-first AI companion",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run build:packages\" \"cd apps/daemon && npm run dev\"",
    "start": "npm run build && node apps/daemon/dist/main.js",
    "build:daemon": "cd apps/daemon && npm run build",
    "dev:renderer": "cd apps/daemon && npm run dev:renderer",
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build --workspaces --if-present",
    "build:apps": "npm run build --workspace=apps/daemon --if-present",
    "test": "npm run test --workspaces --if-present -- --passWithNoTests",
    "test:coverage": "npm run test --workspaces --if-present -- --coverage --passWithNoTests",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "changeset": "changeset",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^8.2.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.2.0"
}
