{
  "name": "@aios/memory",
  "version": "0.1.0",
  "private": true,
  "description": "Memory system with vector database",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "start": "npx serve ."
  },
  "dependencies": {
    "@aios/config": "*",
    "@aios/core": "*",
    "@aios/utils": "*",
    "@assemblyscript/loader": "^0.28.19",
    "@qdrant/js-client-rest": "^1.18.0",
    "qdrant-client": "latest",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "assemblyscript": "^0.28.19",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
